(module workflow
  (effect audit string unit)
  (effect approval string bool)
  (export workflow ((job string)) string
    (handlers
      (audit request resume
        (resume unit))
      (approval request resume
        (resume true)))
    (program
      (let _ (perform audit job))
      (let approved (perform approval job))
      (if approved
        (block
          (return "completed"))
        (block
          (return "rejected"))))))
